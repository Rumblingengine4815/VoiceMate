# Copy this file to .env and fill the API key and model names (do NOT commit .env)
# Use OpenRouter community/open models where available (avoid paid models)
# Example variables:
OPENROUTER_API_KEY=
# CHAT model name provided by OpenRouter (leave empty to select manually)
CHAT_MODEL=
# Whisper / speech-to-text model name (or leave blank to use local Whisper)
WHISPER_MODEL=
# TTS model and voice (or leave blank to use local TTS engine)
TTS_MODEL=
TTS_VOICE=
# SQLite DB filename (default)
DB=voicemate.db
